{
    "name": "matrix-terminal-player",
    "version": "1.0.89",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "node bump-version.js && electron-builder --win"
    },
    "build": {
        "appId": "com.matrix.terminal.player",
        "productName": "MatrixTerminalPlayer",
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64",
                        "ia32"
                    ]
                }
            ],
            "icon": "icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Matrix播放终端"
        },
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "setup.html",
            "package.json",
            "preload.js",
            "bump-version.js",
            "dist"
        ]
    },
    "dependencies": {
        "getmac": "^5.20.0"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1"
    }
}