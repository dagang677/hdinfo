{
    "name": "matrix-server-host",
    "version": "1.0.7",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "node bump-version.js && electron-builder --win"
    },
    "build": {
        "appId": "com.matrix.server.host",
        "productName": "MatrixServerNode",
        "asar": true,
        "asarUnpack": [
            "server.js",
            "dist/**/*",
            "terminal.html",
            "node_modules/**/*"
        ],
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "shortcutName": "Matrix管理服务器"
        },
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "setup.html",
            "loading.html",
            "package.json",
            "server.js",
            "dist/**/*",
            "terminal.html",
            "node_modules/**/*"
        ],
        "extraResources": [
            {
                "from": "icon.png",
                "to": "icon.png"
            },
            {
                "from": "icon.ico",
                "to": "icon.ico"
            }
        ]
    },
    "dependencies": {
        "express": "^4.18.2",
        "cors": "^2.8.5",
        "multer": "^1.4.5-lts.1"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1"
    }
}