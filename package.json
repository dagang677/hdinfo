{
  "name": "matrix-dms-server",
  "version": "1.5.2",
  "description": "Matrix DMS Local Node Engine",
  "main": "server.js",
  "bin": "server.js",
  "pkg": {
    "assets": [
      "dist/**/*",
      "terminal.html"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist-server"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:frontend": "vite",
    "build": "tsc && vite build",
    "package:server": "npm run build && node scripts/copy-build.js && cd server-host && npm install && npm run build",
    "package:player": "cd terminal-player && npm install && npm run build",
    "package-all": "npm run package:server && npm run package:player"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "lucide-react": "^0.563.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "nodemon": "^3.0.2",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}